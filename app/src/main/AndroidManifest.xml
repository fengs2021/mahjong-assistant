<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 悬浮窗权限 -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- 保持屏幕常亮 -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- 网络 (天凤API交叉验证) -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- 日志写入公共目录 -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />

    <!-- Android 11+ 包可见性: 允许查询雀魂 -->
    <queries>
        <package android:name="com.soulgamechst.majsoul" />
        <package android:name="com.majsoul.riichimahjong" />
        <package android:name="com.shengqu.majsoul" />
        <package android:name="com.komoe.majsoulgp" />
        <package android:name="com.dmm.majsoul" />
    </queries>

    <application
        android:requestLegacyExternalStorage="true"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.NoActionBar">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".overlay.OverlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="麻将游戏辅助悬浮窗" />
        </service>

        <!-- 长期截屏服务 (一次授权, 持续持有) -->
        <service
            android:name=".capture.CaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- 截屏权限 Activity -->
        <activity
            android:name=".capture.CaptureActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar"
            android:excludeFromRecents="true" />

        <!-- 手动输入 Activity -->
        <activity
            android:name=".ManualInputActivity"
            android:exported="false" />

        <!-- 识别结果审核 Activity -->
        <activity
            android:name=".ReviewActivity"
            android:exported="false" />

        <!-- 模板校准 Activity -->
        <activity
            android:name=".CalibrateActivity"
            android:exported="false" />



    </application>
</manifest>
